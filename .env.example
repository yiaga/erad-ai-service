# Environment Variables — copy to .env and fill in values

# Server
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/erad_ai?sslmode=disable

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=extraction_jobs
KAFKA_GROUP_ID=erad-ai-service

# Worker pool
WORKER_COUNT=10

# Azure AI Document Intelligence
AZURE_API_KEY=
AZURE_ENDPOINT=

# Google Cloud Document AI
GCP_PROJECT_ID=
GCP_LOCATION=us # or eu
GCP_PROCESSOR_ID=
